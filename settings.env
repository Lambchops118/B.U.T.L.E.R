# =============================================================================
# TALOS settings
# =============================================================================
# This file holds every NON-SECRET setting: hosts, ports, model names, feature
# flags, timeouts, and behavior toggles. It is committed to the repo and ships
# with working defaults, so a fresh clone runs without editing anything here.
#
# Secrets (API keys, tokens, passwords) do NOT go here. They live in `.env`
# (git-ignored). Copy `.env.example` to `.env` and fill those in.
#
# Precedence: a real shell environment variable overrides any value below.
# Uncommented lines are active. Commented (`#`) lines show the default and are
# there for you to enable and adjust. Restart TALOS after editing this file.
# =============================================================================


# --- Language model (streaming lane) -----------------------------------------
# Local Ollama on loopback is the default and needs no API key. Change the model
# name to one returned by `ollama list`. Reference profiles:
#   Ollama (macOS):  TALOS_LLM_BASE_URL=http://127.0.0.1:11434/v1  TALOS_LLM_MODEL=qwen2.5:7b-instruct
#   Ollama:          TALOS_LLM_BASE_URL=http://127.0.0.1:11434/v1  TALOS_LLM_MODEL=mb-core-v1:latest
#   vLLM (CUDA):     TALOS_LLM_BASE_URL=http://127.0.0.1:8000/v1    TALOS_LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
TALOS_LLM_BACKEND=ollama
TALOS_LLM_BASE_URL=http://127.0.0.1:11434/v1
TALOS_LLM_MODEL=hermes3:8b
# Token-limit parameter name. Auto-selected by target (OpenAI ->
# max_completion_tokens, local Ollama/vLLM -> max_tokens); override only if needed.
TALOS_LLM_MAX_TOKENS_PARAM=max_tokens
# Fall back to the hosted OpenAI model when the local backend fails (max
# resilience). Requires OPENAI_API_KEY in .env. Set to 0 to keep everything local.
TALOS_REMOTE_LLM_FALLBACK=1
# TALOS_LLM_TEMPERATURE=
# Dynamic reasoning control for Qwen3-family models (e.g. mb-core-v1). The hidden
# <think> block is the dominant local-model latency cost, so the streamed lane
# appends a per-turn soft switch to the outgoing user message:
#   auto   (default) reason only on complex/analytical requests; suppress it on
#          quick commands and chit-chat (appends /think or /no_think)
#   always force reasoning every turn (/think)
#   never  suppress reasoning every turn (/no_think)
#   off    inject nothing -- set this if you swap to a non-Qwen model that does
#          not understand the /no_think and /think soft switches
# Hermes 3 is a Llama-3.1 fine-tune and does NOT understand Qwen's /think and
# /no_think soft switches; leaving this on "auto" would leak that literal text
# into speech. Set to off for any non-Qwen model.
TALOS_LLM_THINK_MODE=off
# Route classification model (used when the LLM decides which lane handles a
# request). Leave unset to use the default.
# TALOS_ROUTER_MODEL=

# --- Speech-to-text (local faster-whisper) -----------------------------------
# One local pass serves wake + command, replacing the remote whisper-1 round
# trip. Remote fallback stays off by default so local failures never upload
# audio. Requires: pip install faster-whisper
TALOS_LOCAL_STT=1
# Fall back to remote (OpenAI whisper-1) transcription when local STT fails.
# Requires OPENAI_API_KEY in .env. Note: on fallback, audio is uploaded to OpenAI.
# Set to 0 to guarantee audio never leaves the machine.
TALOS_REMOTE_STT_FALLBACK=1
# TALOS_STT_BACKEND=faster_whisper
# TALOS_STT_MODEL=distil-large-v3
# Device/compute auto-select (cuda+int8_float16 on the deploy box, cpu+int8 on Mac).
# TALOS_STT_DEVICE=
# TALOS_STT_COMPUTE_TYPE=
# TALOS_STT_LANGUAGE=en
# TALOS_STT_BEAM_SIZE=1

# --- Voice worker -------------------------------------------------------------
# Stream the agent response and speak it sentence-by-sentence as it generates.
# Set to 0 to use the legacy non-streaming path.
TALOS_VOICE_STREAMING=1
WAKE_WORD=butler
WAKE_WORD_MODE=local
WAKE_WORD_MODEL=base
# Hosted Responses API model used only by the legacy/non-streaming agent lane.
OPENAI_VOICE_MODEL=gpt-4o-mini
# Use the full LLM-based route classification for the voice lane (most accurate
# routing) instead of the fast local heuristic. Set to 0 to prioritize latency.
TALOS_VOICE_MODEL_ROUTING=0
# Force a specific audio output device (index from your audio backend).
# TALOS_AUDIO_OUTPUT_DEVICE_INDEX=

# --- Location / time / weather -----------------------------------------------
TALOS_TIMEZONE=America/New_York
TALOS_WEATHER_LOCATION=Baltimore,US
TALOS_WEATHER_UNITS=imperial

# --- Agent behavior ----------------------------------------------------------
# Raised from the default 8 to allow longer multi-step tool chains.
TALOS_MAX_TOOL_CALL_ROUNDS=16
# Raised from the default 400 so tool-calling requests can emit long structured
# arguments (full recipe step lists, etc.) and longer answers.
TALOS_AGENT_MAX_OUTPUT_TOKENS=1024
# TALOS_OPENAI_SERVER_ERROR_RETRIES=2
# TALOS_OPENAI_SERVER_ERROR_RETRY_DELAY=1.5
# TALOS_OPENAI_SERVER_ERROR_RETRY_JITTER=
# TALOS_OPENAI_SERVER_ERROR_RETRY_MAX_DELAY=
# TALOS_OPENAI_SERVER_ERROR_RECOVERY_ATTEMPTS=
# Expose the full KiCad tool surface instead of the reduced set (default 1 reduces
# it). Only matters when the KiCad MCP helper is configured.
TALOS_REDUCE_KICAD_TOOL_SURFACE=0
# Expose every tool on every turn instead of scoping large single-purpose groups
# (kitchen recipes, etc.) out until the request shows intent. Maximum capability;
# note a local model has a larger tool list to reason over each turn. Set to 1 to
# restore the scoped surface if tool selection degrades.
TALOS_SCOPE_TOOL_SURFACE=0
# Inject the authoritative current date/time into every turn's context so the
# model reads ground truth instead of extrapolating a stale time from earlier
# messages (a local model otherwise tends to increment the last time it stated).
# Set to 0 to disable and rely solely on the get_current_datetime tool.
# TALOS_INJECT_CURRENT_TIME=1
# Recover tool calls that a local model prints as plain text (e.g. a bare
# {"name": ..., "arguments": ...} object or <tool_call>...</tool_call>) instead
# of returning them structured. Set to 0 to disable.
# TALOS_RECOVER_LEAKED_TOOL_CALLS=1

# --- Prompt / personality / conversation memory ------------------------------
# TALOS_PERSONALITY_PATH=/absolute/path/to/custom_personality.md
TALOS_MEMORY_ENABLED=1
# TALOS_MEMORY_DB_PATH=/absolute/path/to/talos_memory.sqlite3
# TALOS_MEMORY_PROJECT_ID=Talos
# TALOS_PROMPT_MEMORY_CHAR_LIMIT=1600
# TALOS_CONVERSATION_HISTORY_MESSAGE_LIMIT=8
# TALOS_CONVERSATION_HISTORY_CHAR_LIMIT=4000
# Local SQLite path for scheduled jobs.
# TALOS_JOBS_DB_PATH=

# --- Text agent server -------------------------------------------------------
# The always-on HTTP agent other clients (GUI, voice worker) talk to.
TEXT_AGENT_ENABLED=1
TEXT_AGENT_HOST=localhost
TEXT_AGENT_PORT=8420
TEXT_AGENT_TIMEOUT=90
TEXT_AGENT_TERMINAL_TIMEOUT=0
# Defaults allow localhost plus Tailscale IPv4/IPv6 ranges.
TEXT_AGENT_ALLOWED_NETWORKS=127.0.0.1/32,::1/128,100.64.0.0/10,fd7a:115c:a1e0::/48

# --- Text agent clients ------------------------------------------------------
TALOS_TEXT_AGENT_URL=http://127.0.0.1:8420
TALOS_TEXT_AGENT_SESSION=main-pc
TALOS_VOICE_SESSION=voice-worker
TALOS_TEXT_AGENT_CLIENT_TIMEOUT=30
TALOS_TEXT_AGENT_TERMINAL_CLIENT_TIMEOUT=0
# TALOS_TEXT_AGENT_EVENT_POLL_SECONDS=
TALOS_TOOL_OUTPUT_CHAR_LIMIT=4000
TALOS_SUMMARIZE_TOOL_OUTPUTS=1
TALOS_TOOL_OUTPUT_SUMMARY_PREVIEW_ITEMS=5
TALOS_TOOL_OUTPUT_SUMMARY_PREVIEW_KEYS=12

# --- MCP servers -------------------------------------------------------------
# If unset, TALOS uses the built-in local aggregate MCP server in
# talos/mcp_server.py. Each server may set "mode" to control its startup:
#   eager  (default) - lightweight provider started during normal boot
#   lazy             - started only when a request actually needs it
#   sidecar_manual   - connect to an already-running local/HTTP MCP endpoint
#   sidecar_autostart- start in background and expose status while it warms
# Remote MCP TLS options per server: "tls_verify": false, "tls_ca_bundle": "/path/ca.pem".
# For a remote server needing a bearer token, set "auth_token_env" to the name of
# an environment variable holding the token (put the token itself in .env).
TALOS_MCP_SERVERS=[{"name":"talos-local","transport":"stdio","command":"python","args":["-m","talos.mcp_server"]}]
# TALOS_MCP_BRIDGE_TIMEOUT=
# TALOS_MCP_FAILURE_THRESHOLD=
# TALOS_MCP_RECONNECT_ATTEMPTS=
# TALOS_MCP_RECONNECT_BACKOFF=

# --- Optional: general filesystem MCP helper ---------------------------------
# Set TALOS_FILESYSTEM_ROOTS to append the official filesystem MCP server plus a
# TALOS diagnostics server (tree summaries, recent-file inspection, ripgrep
# search, diffs). Read-only by default; write tools stay hidden unless writes
# are explicitly allowed. Use a JSON array, e.g.
#   TALOS_FILESYSTEM_ROOTS=["/Users/you/projects","/Volumes/data/share"]
# TALOS_FILESYSTEM_ROOTS=
# TALOS_FILESYSTEM_MODE=eager
# TALOS_FILESYSTEM_ALLOW_WRITES=0
# TALOS_FILESYSTEM_COMMAND=npx
# TALOS_FILESYSTEM_PACKAGE=@modelcontextprotocol/server-filesystem
# TALOS_FILESYSTEM_TIMEOUT=120
# TALOS_FILESYSTEM_DIAGNOSTICS_TIMEOUT=120
# TALOS_FILESYSTEM_RG_TIMEOUT=20
# TALOS_FILESYSTEM_MAX_TEXT_BYTES=1000000
# TALOS_FILESYSTEM_DEFAULT_EXCLUDES=[".git/**","node_modules/**",".venv/**"]
# TALOS_FILESYSTEM_SERVER_NAME=filesystem
# TALOS_FILESYSTEM_DIAGNOSTICS_SERVER_NAME=filesystem-diagnostics
# TALOS_FILESYSTEM_TOOL_PREFIX=fs_

# --- Optional: Minecraft Forge/modpack diagnostics MCP helper ----------------
# Set MINECRAFT_SERVER_DIR to append the official filesystem MCP server plus a
# TALOS ripgrep diagnostics server, both scoped to that directory. Requires
# Node.js/npx, ripgrep (`rg`) on PATH, and @modelcontextprotocol/server-filesystem.
# MINECRAFT_SERVER_DIR=/absolute/path/to/minecraft-server
# MINECRAFT_MCP_MODE=eager
# MINECRAFT_MCP_ALLOW_WRITES=0
# MINECRAFT_MCP_FILESYSTEM_COMMAND=npx
# MINECRAFT_MCP_FILESYSTEM_PACKAGE=@modelcontextprotocol/server-filesystem
# MINECRAFT_MCP_FILESYSTEM_TIMEOUT=120
# MINECRAFT_MCP_SEARCH_TIMEOUT=30
# MINECRAFT_MCP_RG_TIMEOUT=20
# MINECRAFT_MCP_MAX_TEXT_BYTES=1000000
# MINECRAFT_MCP_FILESYSTEM_SERVER_NAME=minecraft-filesystem
# MINECRAFT_MCP_SEARCH_SERVER_NAME=minecraft-search
# MINECRAFT_MCP_FILESYSTEM_TOOL_PREFIX=minecraft_fs_
# MINECRAFT_MCP_SEARCH_TOOL_PREFIX=minecraft_

# --- Optional: KiCad MCP helper ----------------------------------------------
# Set KICAD_MCP_SERVER_PATH to the KiCAD-MCP-Server repo root (or dist/index.js)
# to append it as a stdio MCP server. KiCad is heavyweight, so it defaults to
# sidecar_autostart (background warmup, never blocking ordinary chat).
# KICAD_MCP_SERVER_PATH=/Users/you/MCP/KiCAD-MCP-Server
# KICAD_MCP_MODE=sidecar_autostart          # stdio|sidecar_manual|sidecar_autostart|lazy
# KICAD_MCP_AUTOSTART=background             # background|lazy|false (convenience override for MODE)
# KICAD_MCP_URL=                             # used with sidecar_manual
# KICAD_MCP_COMMAND=node
# KICAD_MCP_SERVER_NAME=kicad
# KICAD_MCP_TOOL_PREFIX=kicad_
# KICAD_BACKEND=ipc
# KICAD_MCP_TIMEOUT=600
# KICAD_READY_TIMEOUT_MS=300000
# KICAD_WARMUP_TIMEOUT_MS=120000
# KICAD_MCP_LOG_LEVEL=info
# KICAD_AUTO_LAUNCH=false
# KICAD_PYTHONPATH=/Applications/KiCad/KiCad.app/Contents/Frameworks/Python.framework/Versions/Current/lib/python3.10/site-packages
# KICAD_PYTHON=
# KICAD_MCP_DEV=0

# --- Optional: kitchen recipe screen -----------------------------------------
# KITCHEN_RECIPE_SCREEN_URL=http://127.0.0.1:8765
# KITCHEN_RECIPE_SCREEN_TIMEOUT=10

# --- Optional: phone calling -------------------------------------------------
# v1 uses ElevenLabs for the live voice conversation and Twilio for PSTN
# transport. TALOS only orchestrates outbound call requests and syncs completed
# calls. Secrets (ELEVENLABS_API_KEY, bridge/push tokens) belong in .env.
TALOS_PHONE_ENABLED=1
TALOS_PHONE_PROVIDER=elevenlabs_twilio
TALOS_PHONE_AGENT_ID=agent_7301kve9j170fk6smj6bmzzhyzdw
TALOS_PHONE_NUMBER_ID=phnum_1701kw7e27s6fnpa6jb4ps8snrpd
# TALOS_PHONE_ALLOWED_OUTBOUND=0
# TALOS_PHONE_BRIDGE_URL=
# TALOS_PHONE_DB_PATH=
# TALOS_PHONE_CONTACTS={"mom":"+15555550123","dad":"+15555550124"}
# TALOS_PHONE_ALLOWLIST=["+15555550123","+15555550124"]
# TALOS_PHONE_BRIDGE_SYNC_LIMIT=25
# Real-time push back to the main process when a call completes. Point at the
# main process's text-agent address (e.g. its Tailscale IP). Unset disables push.
# TALOS_PHONE_MAIN_NOTIFY_URL=http://<main-host>:8420

# =============================================================================
# Awareness subsystem (presence/state/history/alerts/memory backend)
# =============================================================================
# Runs as its own process: .venv-awareness/bin/python -m talos.awareness
# Database: docker compose -f docker-compose.awareness.yml up -d --wait
# Full reference: talos/awareness/README.md
# The DB password and API token are secrets and live in .env
# (TALOS_AWARENESS_DB_PASSWORD, TALOS_AWARENESS_API_TOKEN).
# TALOS_AWARENESS_DB_HOST=127.0.0.1
# TALOS_AWARENESS_DB_PORT=5433
# TALOS_AWARENESS_DB_NAME=talos_awareness
# TALOS_AWARENESS_DB_USER=talos
# TALOS_AWARENESS_API_HOST=127.0.0.1
# TALOS_AWARENESS_API_PORT=8600
# TALOS_AWARENESS_LOG_LEVEL=INFO
# TALOS_AWARENESS_OLLAMA_HOST=http://127.0.0.1:11434
# MQTT defaults fall back to legacy MQTT_BROKER / MQTT_PORT if set:
# TALOS_AWARENESS_MQTT_HOST=192.168.1.160
# TALOS_AWARENESS_MQTT_PORT=1883
# TALOS_AWARENESS_MQTT_CLIENT_ID=talos-awareness
# TALOS_AWARENESS_MQTT_ENABLED=1
# TALOS_AWARENESS_MQTT_KEEPALIVE=60
# TALOS_AWARENESS_MQTT_TOPIC_PREFIX=
# Broker auth/TLS (current Pi broker uses neither; MQTT username/password are
# secrets and belong in .env):
# TALOS_AWARENESS_MQTT_TLS=0
# TALOS_AWARENESS_MQTT_CA_PATH=
# TALOS_AWARENESS_MQTT_CLIENT_CERT=
# TALOS_AWARENESS_MQTT_CLIENT_KEY=
# TALOS_AWARENESS_MAX_EVENT_PAYLOAD_BYTES=65536
# State freshness (per-source registry values override these defaults):
# TALOS_AWARENESS_DEFAULT_STALE_AFTER_SECONDS=300
# TALOS_AWARENESS_DEFAULT_OFFLINE_AFTER_SECONDS=900
# TALOS_AWARENESS_FRESHNESS_INTERVAL_SECONDS=30
# Bounded read queries:
# TALOS_AWARENESS_MAX_QUERY_RANGE_DAYS=31
# TALOS_AWARENESS_MAX_QUERY_POINTS=10000
# TALOS_AWARENESS_MAX_EVENT_PAGE_SIZE=500
# Rules / alerts / notifications:
# TALOS_AWARENESS_RULES_PATH=            # default talos/awareness/rules/rules.toml
# TALOS_AWARENESS_QUIET_HOURS=           # e.g. 22:00-07:00 (noncritical only)
# GUI banner channel: POST /notify on the text server. The notify token
# (TALOS_AWARENESS_NOTIFY_TOKEN, a secret in .env) must match TEXT_AGENT_API_TOKEN;
# unset URL disables the gui channel (log remains).
# TALOS_AWARENESS_NOTIFY_URL=http://127.0.0.1:8420
# TALOS_AWARENESS_NOTIFY_TIMEOUT_SECONDS=5
# TALOS_AWARENESS_OUTBOX_INTERVAL_SECONDS=2
# TALOS_AWARENESS_OUTBOX_BATCH_SIZE=20
# TALOS_AWARENESS_OUTBOX_MAX_ATTEMPTS=8
# TALOS_AWARENESS_OUTBOX_STALE_LOCK_SECONDS=300
# Situation/context:
# TALOS_AWARENESS_SITUATION_BUDGET_TOKENS=600
# TALOS_AWARENESS_SITUATION_MAX_ITEMS_PER_SECTION=20
# TALOS_AWARENESS_SITUATION_TRANSITION_WINDOW_MINUTES=60
# Long-term memory. Embeddings via local Ollama; outage queues work. Dimension
# must match the pgvector column (768) — model-family changes need a migration
# and re-embedding.
# TALOS_AWARENESS_EMBEDDING_MODEL=nomic-embed-text
# TALOS_AWARENESS_EMBEDDING_DIMENSION=768
# TALOS_AWARENESS_MEMORY_STATEMENT_MAX_CHARS=2000
# TALOS_AWARENESS_MEMORY_SEARCH_MAX_LIMIT=50
# Retention / consolidation / backups. Retention runs only when explicitly
# invoked (python -m talos.awareness retention [--execute]); each policy is an
# age in days, 0 disables it.
# TALOS_AWARENESS_RETENTION_BATCH_SIZE=500
# TALOS_AWARENESS_RETENTION_RAW_MEASUREMENTS_DAYS=30
# TALOS_AWARENESS_RETENTION_HEARTBEAT_EVENTS_DAYS=7
# TALOS_AWARENESS_RETENTION_DEAD_LETTER_DAYS=30
# TALOS_AWARENESS_RETENTION_COMPLETED_OUTBOX_DAYS=7
# TALOS_AWARENESS_RETENTION_RESOLVED_ALERTS_DAYS=90
# TALOS_AWARENESS_RETENTION_STATE_TRANSITIONS_DAYS=90
# TALOS_AWARENESS_RETENTION_SOURCE_HEALTH_HISTORY_DAYS=90
# TALOS_AWARENESS_RETENTION_DISCARDED_MEMORIES_DAYS=30
# TALOS_AWARENESS_CONSOLIDATION_EPISODE_THRESHOLD=3
# TALOS_AWARENESS_CONSOLIDATION_WINDOW_DAYS=7
# TALOS_AWARENESS_CONSOLIDATION_DECAY_AFTER_DAYS=60
# TALOS_AWARENESS_CONSOLIDATION_DECAY_FACTOR=0.8
# Backups: nightly local pg_dump, 14-day pruning. Schedule with cron, e.g.:
#   15 3 * * * cd /path/to/Talos && .venv-awareness/bin/python -m talos.awareness backup >> logs/backup.log 2>&1
# TALOS_AWARENESS_BACKUP_DIRECTORY=          # default {data_directory}/backups
# TALOS_AWARENESS_BACKUP_RETENTION_DAYS=14
# Main-agent client for the awareness API (read by the router + MCP tools):
# TALOS_AWARENESS_API_URL=http://127.0.0.1:8600
# TALOS_AWARENESS_CLIENT_TIMEOUT=1.5
# TALOS_AWARENESS_SITUATION_ENABLED=1
