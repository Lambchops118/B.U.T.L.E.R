# =============================================================================
# TALOS secrets — copy this file to `.env` and fill in the values you need.
# =============================================================================
# `.env` holds ONLY secrets: API keys, auth tokens, and passwords. It is
# git-ignored so credentials never land in version control.
#
# All other configuration (hosts, ports, model names, feature flags, timeouts)
# lives in `settings.env`, which is committed with working defaults. You do not
# need to touch settings.env to get started.
#
# Local Ollama inference and local STT need NO keys, so a minimal local setup can
# leave most of this blank. Fill in only the credentials for the hosted
# integrations you actually use.
# =============================================================================

# --- Core hosted integrations ------------------------------------------------
# OpenAI: required only for the hosted (legacy/non-streaming) voice lane and
# remote STT/LLM fallback. Not needed for the local Ollama lane or local STT.
OPENAI_API_KEY=''
# OpenWeather: required for the get_current_weather tool.
OPEN_WEATHER_API_KEY=your_openweather_api_key_here
# AWS (optional hosted services).
AWS_ACCESS_KEY=''
AWS_SECRET_KEY=''
# Hugging Face token (optional; model/dataset downloads).
HF_TOKEN=''

# --- Text agent auth ---------------------------------------------------------
# Shared bearer token for the text agent server and its clients. Leave blank to
# run unauthenticated on a trusted local network; set the same value on both.
TEXT_AGENT_API_TOKEN=
TALOS_TEXT_AGENT_TOKEN=

# --- Language model API key (only for hosted/remote backends) ----------------
# TALOS_LLM_API_KEY=

# --- Awareness subsystem secrets ---------------------------------------------
# Postgres password (required to run the awareness backend).
TALOS_AWARENESS_DB_PASSWORD=change-me
# Bearer token for physical-action request/confirm/cancel routes (min 16 chars).
# The main agent uses the same value when calling the awareness API.
# TALOS_AWARENESS_API_TOKEN=
# Text server bearer token for the awareness GUI-banner channel; must match
# TEXT_AGENT_API_TOKEN above.
# TALOS_AWARENESS_NOTIFY_TOKEN=
# MQTT broker auth (current Pi broker uses neither):
# TALOS_AWARENESS_MQTT_USERNAME=
# TALOS_AWARENESS_MQTT_PASSWORD=

# --- Optional: phone calling -------------------------------------------------
# ELEVENLABS_API_KEY=
# TALOS_PHONE_BRIDGE_TOKEN=
# Shared secret for the phone bridge's real-time push to /phone/events; must
# match TALOS_PHONE_PUSH_TOKEN on the bridge.
# TALOS_PHONE_PUSH_TOKEN=

# --- Optional: separate public phone bridge service --------------------------
# PHONE_BRIDGE_API_TOKEN=
# PHONE_BRIDGE_WEBHOOK_TOKEN=

# --- Optional: remote MCP server tokens --------------------------------------
# Referenced by name via "auth_token_env" in TALOS_MCP_SERVERS (settings.env).
# GITHUB_MCP_TOKEN=
