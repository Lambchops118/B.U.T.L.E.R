# Required API credentials
OPENAI_API_KEY=''
AWS_ACCESS_KEY=''
AWS_SECRET_KEY=''
OPEN_WEATHER_API_KEY=your_openweather_api_key_here

# Optional voice settings
WAKE_WORD=butler
WAKE_WORD_MODE=local
WAKE_WORD_MODEL=base
OPENAI_VOICE_MODEL=gpt-4o-mini
# Skip the extra model-based route classification for the latency-sensitive voice
# lane (uses the local heuristic classifier instead). Set to 1 to restore the LLM
# route decision for voice commands.
TALOS_VOICE_MODEL_ROUTING=0
# Stream the agent response and speak it sentence-by-sentence as it generates
# (voice worker). Set to 0 to use the legacy non-streaming path.
TALOS_VOICE_STREAMING=1
# Streaming LLM backend (Chat Completions). Defaults to OpenAI + OPENAI_VOICE_MODEL
# with the existing key. Point these at a local server to go fully local with no
# code change:
#   Ollama (macOS):  TALOS_LLM_BASE_URL=http://127.0.0.1:11434/v1  TALOS_LLM_MODEL=qwen2.5:7b-instruct
#   vLLM (CUDA):     TALOS_LLM_BASE_URL=http://127.0.0.1:8000/v1    TALOS_LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
# TALOS_LLM_BASE_URL=
# TALOS_LLM_MODEL=
# TALOS_LLM_API_KEY=
# Token-limit parameter name. Auto-selected by target (OpenAI ->
# max_completion_tokens, local Ollama/vLLM -> max_tokens); override only if needed.
# TALOS_LLM_MAX_TOKENS_PARAM=
# Local speech-to-text (faster-whisper). One local pass serves wake + command,
# replacing the remote whisper-1 round-trip. Falls back to remote automatically if
# the backend is unavailable. Requires: pip install faster-whisper
TALOS_LOCAL_STT=1
# TALOS_STT_BACKEND=faster_whisper
# TALOS_STT_MODEL=distil-large-v3
# Device/compute auto-select (cuda+int8_float16 on the deploy box, cpu+int8 on Mac).
# TALOS_STT_DEVICE=
# TALOS_STT_COMPUTE_TYPE=
# TALOS_STT_LANGUAGE=en
# TALOS_STT_BEAM_SIZE=1
TALOS_TIMEZONE=America/New_York
TALOS_WEATHER_LOCATION=New York,US
TALOS_WEATHER_UNITS=imperial

# Optional phone calling settings
# v1 uses ElevenLabs for the live voice conversation and Twilio for PSTN transport.
# TALOS only orchestrates outbound call requests and syncs completed-call history.
# TALOS_PHONE_ENABLED=1
# TALOS_PHONE_PROVIDER=elevenlabs_twilio
# ELEVENLABS_API_KEY=
# TALOS_PHONE_AGENT_ID=
# TALOS_PHONE_NUMBER_ID=
# TALOS_PHONE_ALLOWED_OUTBOUND=0
# TALOS_PHONE_BRIDGE_URL=
# TALOS_PHONE_BRIDGE_TOKEN=
# Shared secret for the phone bridge's real-time push to this process's
# /phone/events endpoint. Must match TALOS_PHONE_PUSH_TOKEN on the bridge.
# TALOS_PHONE_PUSH_TOKEN=
# TALOS_PHONE_DB_PATH=
# TALOS_PHONE_CONTACTS={"mom":"+15555550123","dad":"+15555550124"}
# TALOS_PHONE_ALLOWLIST=["+15555550123","+15555550124"]
# TALOS_PHONE_BRIDGE_SYNC_LIMIT=25

# Optional MCP server configuration
# If unset, TALOS uses the built-in local aggregate MCP server in talos/mcp_server.py.
# Each server may set "mode" to control its startup lifecycle:
#   eager  (default) - lightweight provider started during normal agent boot/tool discovery
#   lazy             - started only when a request actually needs it
#   sidecar_manual   - connect to an already-running local/HTTP MCP endpoint on demand
#   sidecar_autostart- start in the background and expose status while it warms (non-blocking)
# Deferred modes (lazy/sidecar_*) keep heavyweight providers out of ordinary chat startup.
# TALOS_MCP_SERVERS=[{"name":"talos-local","transport":"stdio","command":"python","args":["-m","talos.mcp_server"]},{"name":"github","transport":"streamable_http","url":"https://example.com/mcp","auth_token_env":"GITHUB_MCP_TOKEN","tool_prefix":"github_","mode":"eager"}]
# Remote MCP TLS options:
#   "tls_verify": false                  disable certificate verification for one server
#   "tls_ca_bundle": "/path/to/ca.pem"  use a custom CA bundle for one server
# GITHUB_MCP_TOKEN=
# TALOS_MAX_TOOL_CALL_ROUNDS=8
# TALOS_AGENT_MAX_OUTPUT_TOKENS=400
# TALOS_OPENAI_SERVER_ERROR_RETRIES=2
# TALOS_OPENAI_SERVER_ERROR_RETRY_DELAY=1.5
# TALOS_REDUCE_KICAD_TOOL_SURFACE=1
# KITCHEN_RECIPE_SCREEN_URL=http://127.0.0.1:8765
# KITCHEN_RECIPE_SCREEN_TIMEOUT=10

# Prompt/personality and local conversation-memory settings
# TALOS_PERSONALITY_PATH=/absolute/path/to/custom_personality.md
TALOS_MEMORY_ENABLED=1
# TALOS_MEMORY_DB_PATH=/absolute/path/to/talos_memory.sqlite3
# TALOS_MEMORY_PROJECT_ID=Talos
# TALOS_PROMPT_MEMORY_CHAR_LIMIT=1600

# Optional general filesystem MCP helper.
# Set TALOS_FILESYSTEM_ROOTS to have TALOS append:
#   - the official filesystem MCP server for directory listing/reading/editing
#   - a TALOS-owned diagnostics MCP server for root-scoped tree summaries,
#     recent-file inspection, ripgrep-based text search, and text diffs
# Use a JSON array when possible, for example:
#   TALOS_FILESYSTEM_ROOTS=["/Users/you/projects","/Volumes/data/share"]
# Read-only is the default user experience; write-capable filesystem tools stay
# hidden unless TALOS_FILESYSTEM_ALLOW_WRITES is enabled explicitly.
# TALOS_FILESYSTEM_ROOTS=
# TALOS_FILESYSTEM_MODE=eager
# TALOS_FILESYSTEM_ALLOW_WRITES=0
# TALOS_FILESYSTEM_COMMAND=npx
# TALOS_FILESYSTEM_PACKAGE=@modelcontextprotocol/server-filesystem
# TALOS_FILESYSTEM_TIMEOUT=120
# TALOS_FILESYSTEM_DIAGNOSTICS_TIMEOUT=120
# TALOS_FILESYSTEM_RG_TIMEOUT=20
# TALOS_FILESYSTEM_MAX_TEXT_BYTES=1000000
# TALOS_FILESYSTEM_DEFAULT_EXCLUDES=[".git/**","node_modules/**",".venv/**"]
# TALOS_FILESYSTEM_SERVER_NAME=filesystem
# TALOS_FILESYSTEM_DIAGNOSTICS_SERVER_NAME=filesystem-diagnostics
# TALOS_FILESYSTEM_TOOL_PREFIX=fs_

# Optional Minecraft Forge/modpack diagnostics MCP helper.
# Set MINECRAFT_SERVER_DIR to have TALOS append:
#   - the official filesystem MCP server scoped to that directory only
#   - a TALOS-owned ripgrep diagnostics MCP server that enforces the same root
# Read-only is the default behavior at the agent level; write-capable filesystem
# tools stay hidden unless MINECRAFT_MCP_ALLOW_WRITES is enabled explicitly.
# Requires:
#   - Node.js / npx
#   - ripgrep (`rg`) on PATH
#   - @modelcontextprotocol/server-filesystem available via npx or local install
# MINECRAFT_SERVER_DIR=/absolute/path/to/minecraft-server
# MINECRAFT_MCP_MODE=eager
# MINECRAFT_MCP_ALLOW_WRITES=0
# MINECRAFT_MCP_FILESYSTEM_COMMAND=npx
# MINECRAFT_MCP_FILESYSTEM_PACKAGE=@modelcontextprotocol/server-filesystem
# MINECRAFT_MCP_FILESYSTEM_TIMEOUT=120
# MINECRAFT_MCP_SEARCH_TIMEOUT=30
# MINECRAFT_MCP_RG_TIMEOUT=20
# MINECRAFT_MCP_MAX_TEXT_BYTES=1000000
# MINECRAFT_MCP_FILESYSTEM_SERVER_NAME=minecraft-filesystem
# MINECRAFT_MCP_SEARCH_SERVER_NAME=minecraft-search
# MINECRAFT_MCP_FILESYSTEM_TOOL_PREFIX=minecraft_fs_
# MINECRAFT_MCP_SEARCH_TOOL_PREFIX=minecraft_

# Optional KiCad MCP helper. Set KICAD_MCP_SERVER_PATH to the KiCAD-MCP-Server repo
# root (or dist/index.js) to have TALOS append it as a stdio MCP server automatically.
# KICAD_MCP_SERVER_PATH=/Users/you/MCP/KiCAD-MCP-Server
# KiCad is heavyweight, so it defaults to sidecar_autostart (background warmup,
# never blocking ordinary chat). Override with KICAD_MCP_MODE or KICAD_MCP_AUTOSTART.
#   KICAD_MCP_MODE=stdio|sidecar_manual|sidecar_autostart|lazy
#   KICAD_MCP_AUTOSTART=background|lazy|false   (convenience override for MODE)
#   KICAD_MCP_URL=http://127.0.0.1:8765/mcp     (used with sidecar_manual)
# KICAD_MCP_MODE=sidecar_autostart
# KICAD_MCP_AUTOSTART=background
# KICAD_MCP_URL=
# KICAD_MCP_COMMAND=node
# KICAD_MCP_SERVER_NAME=kicad
# KICAD_MCP_TOOL_PREFIX=kicad_
# KICAD_BACKEND=ipc
# KICAD_MCP_TIMEOUT=600
# KICAD_READY_TIMEOUT_MS=300000
# KICAD_WARMUP_TIMEOUT_MS=120000
# KICAD_MCP_LOG_LEVEL=info
# KICAD_AUTO_LAUNCH=false
# KICAD_PYTHONPATH=/Applications/KiCad/KiCad.app/Contents/Frameworks/Python.framework/Versions/Current/lib/python3.10/site-packages
# KICAD_PYTHON=
# KICAD_MCP_DEV=0

# Text agent server
TEXT_AGENT_ENABLED=1
TEXT_AGENT_HOST=0.0.0.0
TEXT_AGENT_PORT=8420
TEXT_AGENT_API_TOKEN=
TEXT_AGENT_TIMEOUT=90
TEXT_AGENT_TERMINAL_TIMEOUT=0
# Defaults allow localhost plus Tailscale IPv4/IPv6 ranges.
TEXT_AGENT_ALLOWED_NETWORKS=127.0.0.1/32,::1/128,100.64.0.0/10,fd7a:115c:a1e0::/48

# Local/remote clients for the text agent
TALOS_TEXT_AGENT_URL=http://127.0.0.1:8420
TALOS_TEXT_AGENT_TOKEN=
TALOS_TEXT_AGENT_SESSION=main-pc
TALOS_VOICE_SESSION=voice-worker
TALOS_TEXT_AGENT_CLIENT_TIMEOUT=30
TALOS_TEXT_AGENT_TERMINAL_CLIENT_TIMEOUT=0
TALOS_TOOL_OUTPUT_CHAR_LIMIT=4000
TALOS_SUMMARIZE_TOOL_OUTPUTS=1
TALOS_TOOL_OUTPUT_SUMMARY_PREVIEW_ITEMS=5
TALOS_TOOL_OUTPUT_SUMMARY_PREVIEW_KEYS=12

# Awareness subsystem (presence/state/history/alerts/memory backend).
# Runs as its own process: .venv-awareness/bin/python -m talos.awareness
# Database: docker compose -f docker-compose.awareness.yml up -d --wait
# Full reference: talos/awareness/README.md
TALOS_AWARENESS_DB_PASSWORD=change-me
# TALOS_AWARENESS_DB_HOST=127.0.0.1
# TALOS_AWARENESS_DB_PORT=5433
# TALOS_AWARENESS_DB_NAME=talos_awareness
# TALOS_AWARENESS_DB_USER=talos
# TALOS_AWARENESS_API_HOST=127.0.0.1
# TALOS_AWARENESS_API_PORT=8600
# Required for physical-action request/confirm/cancel routes (minimum 16 chars).
# The main agent uses the same value when calling the awareness API.
# TALOS_AWARENESS_API_TOKEN=
# TALOS_AWARENESS_LOG_LEVEL=INFO
# TALOS_AWARENESS_OLLAMA_HOST=http://127.0.0.1:11434
# MQTT defaults fall back to legacy MQTT_BROKER / MQTT_PORT if set:
# TALOS_AWARENESS_MQTT_HOST=192.168.1.160
# TALOS_AWARENESS_MQTT_PORT=1883
# TALOS_AWARENESS_MQTT_CLIENT_ID=talos-awareness
# TALOS_AWARENESS_MQTT_ENABLED=1
# TALOS_AWARENESS_MQTT_KEEPALIVE=60
# TALOS_AWARENESS_MQTT_TOPIC_PREFIX=
# Broker auth/TLS (the current Pi broker uses neither; supported for later
# hardening — see DISCOVERY.md and Phase 8):
# TALOS_AWARENESS_MQTT_USERNAME=
# TALOS_AWARENESS_MQTT_PASSWORD=
# TALOS_AWARENESS_MQTT_TLS=0
# TALOS_AWARENESS_MQTT_CA_PATH=
# TALOS_AWARENESS_MQTT_CLIENT_CERT=
# TALOS_AWARENESS_MQTT_CLIENT_KEY=
# TALOS_AWARENESS_MAX_EVENT_PAYLOAD_BYTES=65536
# State freshness (Phase 3; per-source registry values override the defaults):
# TALOS_AWARENESS_DEFAULT_STALE_AFTER_SECONDS=300
# TALOS_AWARENESS_DEFAULT_OFFLINE_AFTER_SECONDS=900
# TALOS_AWARENESS_FRESHNESS_INTERVAL_SECONDS=30
# Bounded read queries (Phase 3):
# TALOS_AWARENESS_MAX_QUERY_RANGE_DAYS=31
# TALOS_AWARENESS_MAX_QUERY_POINTS=10000
# TALOS_AWARENESS_MAX_EVENT_PAGE_SIZE=500
# Rules / alerts / notifications (Phase 4):
# TALOS_AWARENESS_RULES_PATH=            # default talos/awareness/rules/rules.toml
# TALOS_AWARENESS_QUIET_HOURS=           # e.g. 22:00-07:00 (noncritical only)
# GUI banner channel: POST /notify on the text server. The token must match
# TEXT_AGENT_API_TOKEN above; unset URL disables the gui channel (log remains).
# TALOS_AWARENESS_NOTIFY_URL=http://127.0.0.1:8420
# TALOS_AWARENESS_NOTIFY_TOKEN=
# TALOS_AWARENESS_NOTIFY_TIMEOUT_SECONDS=5
# TALOS_AWARENESS_OUTBOX_INTERVAL_SECONDS=2
# TALOS_AWARENESS_OUTBOX_BATCH_SIZE=20
# TALOS_AWARENESS_OUTBOX_MAX_ATTEMPTS=8
# TALOS_AWARENESS_OUTBOX_STALE_LOCK_SECONDS=300
# Situation/context (Phase 5):
# TALOS_AWARENESS_SITUATION_BUDGET_TOKENS=600
# TALOS_AWARENESS_SITUATION_MAX_ITEMS_PER_SECTION=20
# TALOS_AWARENESS_SITUATION_TRANSITION_WINDOW_MINUTES=60
# Long-term memory (Phase 6). Embeddings via local Ollama; outage queues work.
# Dimension must match the pgvector column (768) — model-family changes need a
# migration and re-embedding.
# TALOS_AWARENESS_EMBEDDING_MODEL=nomic-embed-text
# TALOS_AWARENESS_EMBEDDING_DIMENSION=768
# TALOS_AWARENESS_MEMORY_STATEMENT_MAX_CHARS=2000
# TALOS_AWARENESS_MEMORY_SEARCH_MAX_LIMIT=50
# Retention / consolidation / backups (Phase 8). Retention runs only when
# explicitly invoked (python -m talos.awareness retention [--execute]);
# each policy is an age in days, 0 disables it.
# TALOS_AWARENESS_RETENTION_BATCH_SIZE=500
# TALOS_AWARENESS_RETENTION_RAW_MEASUREMENTS_DAYS=30
# TALOS_AWARENESS_RETENTION_HEARTBEAT_EVENTS_DAYS=7
# TALOS_AWARENESS_RETENTION_DEAD_LETTER_DAYS=30
# TALOS_AWARENESS_RETENTION_COMPLETED_OUTBOX_DAYS=7
# TALOS_AWARENESS_RETENTION_RESOLVED_ALERTS_DAYS=90
# TALOS_AWARENESS_RETENTION_STATE_TRANSITIONS_DAYS=90
# TALOS_AWARENESS_RETENTION_SOURCE_HEALTH_HISTORY_DAYS=90
# TALOS_AWARENESS_RETENTION_DISCARDED_MEMORIES_DAYS=30
# TALOS_AWARENESS_CONSOLIDATION_EPISODE_THRESHOLD=3
# TALOS_AWARENESS_CONSOLIDATION_WINDOW_DAYS=7
# TALOS_AWARENESS_CONSOLIDATION_DECAY_AFTER_DAYS=60
# TALOS_AWARENESS_CONSOLIDATION_DECAY_FACTOR=0.8
# Backups: nightly local pg_dump (owner decision 2026-07-16), 14-day pruning.
# Schedule with cron, e.g.:
#   15 3 * * * cd /path/to/Talos && .venv-awareness/bin/python -m talos.awareness backup >> logs/backup.log 2>&1
# TALOS_AWARENESS_BACKUP_DIRECTORY=          # default {data_directory}/backups
# TALOS_AWARENESS_BACKUP_RETENTION_DAYS=14
# Main-agent client for the awareness API (read by the router + MCP tools):
# TALOS_AWARENESS_API_URL=http://127.0.0.1:8600
# TALOS_AWARENESS_CLIENT_TIMEOUT=1.5
# TALOS_AWARENESS_SITUATION_ENABLED=1

# Separate public phone bridge service
# Run this outside the private TALOS host, for example:
#   uvicorn talos.phone_bridge.app:app --host 0.0.0.0 --port 8787
# PHONE_BRIDGE_API_TOKEN=
# PHONE_BRIDGE_WEBHOOK_TOKEN=
# Real-time push back to the main TALOS process when a call completes, so the
# main agent learns about it immediately instead of waiting to be asked.
# Point this at the main process's text-agent address (e.g. its Tailscale IP).
# Leave unset to disable the push; the main process still picks up completed
# calls the next time it calls a phone tool (lazy pull via TALOS_PHONE_BRIDGE_URL).
# TALOS_PHONE_MAIN_NOTIFY_URL=http://<main-host>:8420
# TALOS_PHONE_PUSH_TOKEN=


TALOS_MCP_SERVERS=[{"name":"talos-local","transport":"stdio","command":"python","args":["-m","talos.mcp_server"]}]
